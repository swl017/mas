Panels:
  - Class: rviz_common/Displays
    Help Height: 70
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /Global Options1
        - /A8 Compressed1/Topic1
      Splitter Ratio: 0.5
    Tree Height: 400
  - Class: rviz_common/Selection
    Name: Selection
  - Class: rviz_common/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.5
      Cell Size: 1
      Class: rviz_default_plugins/Grid
      Color: 160; 160; 164
      Enabled: false
      Line Style:
        Line Width: 0.03
        Value: Lines
      Name: Grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 10
      Reference Frame: <Fixed Frame>
      Value: false
    # --- A8 compressed image via image_transport ---
    #
    # Image display: topic is the BASE name (/a8/image_raw). rviz2's
    # image_transport picks the plugin named in Transport Hint, which
    # subscribes to /a8/image_raw/compressed under the hood.
    #
    # QoS must be BEST_EFFORT to match the rtsp_camera publisher
    # (SensorDataQoS). RELIABLE would be refused as incompatible and
    # no frames would render.
    - Class: rviz_default_plugins/Image
      Enabled: true
      Max Value: 1
      Median window: 5
      Min Value: 0
      Name: A8 Compressed
      Normalize Range: true
      # Depth=1 on both the DDS subscription and the image_transport
      # filter: rviz renders at ~19 Hz, publisher ships at ~22 Hz, so any
      # Depth>1 silently queues the 3 extra frames/s and the user sees
      # latency accumulate indefinitely. With Depth=1 the subscription
      # always drops to the newest frame; a few frames/sec are discarded
      # but what's rendered is always current.
      Topic:
        Depth: 1
        Durability Policy: Volatile
        Filter size: 1
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /a8/image_raw
      Transport Hint: compressed
      Value: true
  Enabled: true
  Global Options:
    Background Color: 48; 48; 48
    Default Light: true
    Fixed Frame: a8
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz_default_plugins/MoveCamera
    - Class: rviz_default_plugins/FocusCamera
  Transformation:
    Current:
      Class: rviz_default_plugins/TF
  Value: true
  Views:
    Current:
      Class: rviz_default_plugins/Orbit
      Distance: 10
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.06
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Focal Point:
        X: 0
        Y: 0
        Z: 0
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.05
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.01
      Pitch: 0.785
      Target Frame: <Fixed Frame>
      Value: Orbit (rviz)
      Yaw: 0.785
    Saved: ~
Window Geometry:
  Displays:
    collapsed: false
  Height: 900
  Hide Left Dock: false
  Hide Right Dock: false
  A8 Compressed:
    collapsed: false
  QMainWindow State: 
  Selection:
    collapsed: false
  Views:
    collapsed: false
  Width: 1440
  X: 60
  Y: 60
