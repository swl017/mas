ros_ego: "Ego ROS2 Topics" {
  style: {
    fill: "#999"
    stroke: "#6b6b6b"
    font-color: "#fff"
    border-radius: 8
    font-size: 24
  }
  desc: "common_frame/odom\nmavros/imu/data\ngimbal_state_rpy_deg\nyolo_result_vision\ncamera/zoom_level\nchosen_target_ray_w" {
    shape: text
    style.font-size: 13
  }
}

ros_peer: "Peer ROS2 Topics" {
  style: {
    fill: "#d4edda"
    stroke: "#6abf69"
    font-color: "#333"
    border-radius: 8
    font-size: 24
    multiple: true
  }
  desc: "/{peer}/common_frame/odom\n/{peer}/combined_ang_vel_w\n/{peer}/yolo_result_active\n/{peer}/camera/zoom_level\n/{peer}/chosen_target_ray_w\n/{peer}/policy/observation" {
    shape: text
    style.font-size: 13
  }
}

ros_out: "Output Topics" {
  style: {
    fill: "#999"
    stroke: "#6b6b6b"
    font-color: "#fff"
    border-radius: 8
    font-size: 24
  }
  desc: "policy/cmd_vel\npolicy/gimbal_cmd_los_rate\npolicy/zoom_rate_cmd\npolicy/value\npolicy/observation" {
    shape: text
    style.font-size: 13
  }
}

checkpoint: "SKRL Checkpoint\n(.pt file)" {
  style: {
    fill: "#999"
    stroke: "#6b6b6b"
    font-color: "#fff"
    border-radius: 8
    font-size: 24
  }
}

ros_ego -> mas_policy.assembler: "subscriptions" {
  style.stroke: "#707070"
}
ros_peer -> mas_policy.assembler: "subscriptions" {
  style.stroke: "#2d6a2d"
  style.stroke-dash: 3
}
mas_policy.action_pub -> ros_out: "publish" {
  style.stroke: "#707070"
}
checkpoint -> mas_policy.load_ckpt: "load at init" {
  style.stroke: "#707070"
}
