# MAS C4 Level 4 вЂ” Code: mas_policy
# Render: d2 c4_L4_policy.d2 c4_L4_policy.svg --layout=elk

direction: right

title: {
  label: "MAS вЂ” mas_policy Code Diagram (C4 Level 4)"
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
# mas_policy package boundary
# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

mas_policy: mas_policy {
  style: {
    fill: "#e8f0fe"
    stroke: "#438dd5"
    stroke-width: 2
    font-size: 24
  }

  # в”Ђв”Ђ PolicyDeployNode в”Ђв”Ђ

  policy_node: PolicyDeployNode {
    style: {
      fill: "#85bbf0"
      stroke: "#5d99c6"
      font-color: "#000"
      border-radius: 8
      font-size: 24
    }
    desc: "[Class: rclpy Node]\npolicy_node.py\n\n_control_loop() @ 25 Hz:\n  1. assembler.assemble() в†’ obs\n  2. scaler.normalize(obs)\n  3. policy(obs_norm, hidden) в†’ action\n  4. cbf_filter.filter(v_nom) в†’ v_safe\n  5. action_pub.publish(action)\n\n_reset_hidden_callback()\n_peer_obs_callback()" {
      shape: text
      style.font-size: 13
    }
  }

  # в”Ђв”Ђ ObservationAssembler в”Ђв”Ђ

  assembler: ObservationAssembler {
    style: {
      fill: "#85bbf0"
      stroke: "#5d99c6"
      font-color: "#000"
      border-radius: 8
      font-size: 24
    }
    desc: "[Class]\nobservation_assembler.py\n\nassemble() в†’ np.ndarray (62/68D)\n\nEgo (30D): pos, vel, euler, ang_vel,\n  lin_acc, gimbal(yaw,pitch), ray_dir,\n  combined_ang_vel, bbox_aoi, zoom,\n  bbox_xywh, bbox_empty\n\nPer-peer (16D): pos, vel, ray_dir,\n  combined_ang_vel, zoom, bbox_empty,\n  data_age, bbox_age\n\nOptional tri tail (6D): pos, std_dev" {
      shape: text
      style.font-size: 13
    }
  }

  # в”Ђв”Ђ VehicleState в”Ђв”Ђ

  vehicle_state: VehicleState {
    style: {
      fill: "#d4e8fc"
      stroke: "#5d99c6"
      font-color: "#000"
      border-radius: 8
      font-size: 24
    }
    desc: "[Dataclass]\n\nposition_w, velocity_w (3)\norientation_w (4, wxyz)\nangular_velocity_b (3)\nlinear_acceleration_b (3)\ngimbal_yaw/pitch_body\nbbox_xywh (4), bbox_empty\nzoom_level\ncombined_ang_vel_w (3)\nchosen_target_ray_w (3)\nmotion/gimbal/detection timestamps" {
      shape: text
      style.font-size: 13
    }
  }

  # в”Ђв”Ђ ActionPublisher в”Ђв”Ђ

  action_pub: ActionPublisher {
    style: {
      fill: "#85bbf0"
      stroke: "#5d99c6"
      font-color: "#000"
      border-radius: 8
      font-size: 24
    }
    desc: "[Class]\naction_publisher.py\n\npublish(action: 7D np.ndarray)\npublish_zero()\n\nDenormalize [-1,1] в†’ physical:\n  [0-2] Г— max_lin_vel в†’ cmd_vel.linear\n  [3] Г— max_yaw_rate в†’ cmd_vel.angular.z\n  [4-5] Г— max_gimbal_rate в†’ gimbal LOS rate\n  [6] Г— max_zoom_rate в†’ zoom rate" {
      shape: text
      style.font-size: 13
    }
  }

  # в”Ђв”Ђ PolicyNetRNN в”Ђв”Ђ

  policy_rnn: PolicyNetRNN {
    style: {
      fill: "#c5e1a5"
      stroke: "#7cb342"
      font-color: "#000"
      border-radius: 8
      font-size: 24
    }
    desc: "[nn.Module]\npolicy_loader.py\n\nLinearв†’ReLUв†’Linearв†’ReLU\nв†’GRUв†’Linear(action_dim)\n\nforward(obs, hidden)\n  в†’ (action, new_hidden)\ninit_hidden(device) в†’ zeros" {
      shape: text
      style.font-size: 13
    }
  }

  # в”Ђв”Ђ PolicyNetMLP в”Ђв”Ђ

  policy_mlp: PolicyNetMLP {
    style: {
      fill: "#c5e1a5"
      stroke: "#7cb342"
      font-color: "#000"
      border-radius: 8
      font-size: 24
    }
    desc: "[nn.Module]\npolicy_loader.py\n\nLinearв†’ELUв†’Linearв†’ELU\nв†’Linear(action_dim)\n\nforward(obs) в†’ action" {
      shape: text
      style.font-size: 13
    }
  }

  # в”Ђв”Ђ ValueNetRNN в”Ђв”Ђ

  value_rnn: ValueNetRNN {
    style: {
      fill: "#c5e1a5"
      stroke: "#7cb342"
      font-color: "#000"
      border-radius: 8
      font-size: 24
    }
    desc: "[nn.Module]\npolicy_loader.py\n\nSame arch as PolicyNetRNN\nв†’ Linear(1)\n\nforward(shared_obs, hidden)\n  в†’ (value, new_hidden)\n\nInput: concat(ego_obs, peer_obs...)" {
      shape: text
      style.font-size: 13
    }
  }

  # в”Ђв”Ђ ScalerState в”Ђв”Ђ

  scaler: ScalerState {
    style: {
      fill: "#d4e8fc"
      stroke: "#5d99c6"
      font-color: "#000"
      border-radius: 8
      font-size: 24
    }
    desc: "[Dataclass]\npolicy_loader.py\n\nrunning_mean (obs_dim,)\nrunning_var (obs_dim,)\n\nnormalize(obs)\n  в†’ (obs - mean) / sqrt(var + Оµ)" {
      shape: text
      style.font-size: 13
    }
  }

  # в”Ђв”Ђ DeploymentCBFFilter в”Ђв”Ђ

  cbf: DeploymentCBFFilter {
    style: {
      fill: "#f8d7da"
      stroke: "#d9534f"
      font-color: "#000"
      border-radius: 8
      font-size: 24
    }
    desc: "[Class]\ncbf_filter.py\n\nfilter(v_nom, positions, velocities)\n  в†’ (v_safe, info)\n\nGauss-Seidel projection:\n  For each agent pair (i,j):\n    h = ||p_i - p_j||ВІ - D_deployВІ\n    Project v_i onto halfspace\n\nD_deploy = D_s + v_max(П„_delay + П„_px4)" {
      shape: text
      style.font-size: 13
    }
  }

  # в”Ђв”Ђ Utils в”Ђв”Ђ

  utils: utils {
    style: {
      fill: "#fff9c4"
      stroke: "#f9a825"
      font-color: "#000"
      border-radius: 8
      font-size: 24
    }
    desc: "[Module]\nutils.py\n\neuler_xyz_from_quat(wxyz)\nquat_rotate(q, v)\ngimbal_ray_direction_world()\nwrap_to_pi()\nned_to_enu_position/velocity()\nfrd_to_flu_angular_velocity()\nquat_ned_frd_to_enu_flu()" {
      shape: text
      style.font-size: 13
    }
  }

  # в”Ђв”Ђ load_checkpoint в”Ђв”Ђ

  load_ckpt: load_checkpoint() {
    style: {
      fill: "#fff9c4"
      stroke: "#f9a825"
      font-color: "#000"
      border-radius: 8
      font-size: 24
    }
    desc: "[Function]\npolicy_loader.py\n\nLoad SKRL .pt checkpoint\nв†’ (PolicyNet, ScalerState,\n   ValueNet, SharedScaler)\n\nHandles agent_id extraction,\nprefix stripping, architecture\nselection" {
      shape: text
      style.font-size: 13
    }
  }

  # в”Ђв”Ђ Relationships в”Ђв”Ђ

  policy_node -> assembler: "owns\nassemble() в†’ obs" {
    style.stroke: "#333"
  }
  policy_node -> action_pub: "owns\npublish(action)" {
    style.stroke: "#333"
  }
  policy_node -> cbf: "owns\nfilter(v_nom)" {
    style.stroke: "#333"
  }
  policy_node -> policy_rnn: "uses\nforward(obs, hidden)" {
    style.stroke: "#333"
    style.stroke-dash: 3
  }
  policy_node -> policy_mlp: "uses (alt)\nforward(obs)" {
    style.stroke: "#333"
    style.stroke-dash: 3
  }
  policy_node -> value_rnn: "uses (optional)\nforward(shared_obs)" {
    style.stroke: "#333"
    style.stroke-dash: 3
  }
  policy_node -> scaler: "uses\nnormalize(obs)" {
    style.stroke: "#333"
  }
  assembler -> vehicle_state: "caches\nper-vehicle state" {
    style.stroke: "#333"
  }
  assembler -> utils: "calls\neuler, quat_rotate,\ngimbal_ray_direction" {
    style.stroke: "#999"
    style.stroke-dash: 3
  }
  load_ckpt -> policy_rnn: "creates" {
    style.stroke: "#7cb342"
  }
  load_ckpt -> policy_mlp: "creates" {
    style.stroke: "#7cb342"
  }
  load_ckpt -> value_rnn: "creates" {
    style.stroke: "#7cb342"
  }
  load_ckpt -> scaler: "creates" {
    style.stroke: "#7cb342"
  }
}

# в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
