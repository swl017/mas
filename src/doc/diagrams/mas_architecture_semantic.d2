# MAS (Multi-Agent C-UAS System, Per-Vehicle Decentralized Architecture)
# Semantic-level Architecture Diagram
# Render: d2 mas_architecture_semantic.d2 mas_architecture_semantic.svg --layout=elk

direction: right

title: {
  label: "MAS (Multi-Agent C-UAS System, Per-Vehicle Decentralized Architecture)"
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

# ═══════════════════════════════════════════════════════════
# Agent N+1 (peer instance, green)
# ═══════════════════════════════════════════════════════════

agent_n1: "Agent N+1 (MAS instance)" {
  style: {
    fill: "#d4edda"
    stroke: "#6abf69"
    stroke-width: 2
    multiple: true
  }

  mavros_n1: MAVROS {
    style.fill: "#fff"
  }
  mas_common_frame_n1: mas_common_frame {
    style.fill: "#fff"
  }
  ultralytics_ros_n1: ultralytics_ros {
    style.fill: "#fff"
  }
  mas_multiview_n1: mas_multiview {
    style.fill: "#fff"
  }
  mas_tracker_n1: mas_tracker {
    style.fill: "#fff"
  }

  mavros_n1 -> mas_common_frame_n1
  ultralytics_ros_n1 -> mas_multiview_n1
  mas_multiview_n1 -> mas_tracker_n1
}

# ═══════════════════════════════════════════════════════════
# Agent N (main instance, blue)
# ═══════════════════════════════════════════════════════════

agent_n: "Agent N (MAS instance N)" {
  style: {
    fill: "#dbeeff"
    stroke: "#4a90d9"
    stroke-width: 2
  }

  ultralytics_ros: ultralytics_ros {
    style.fill: "#fff"
  }
  mas_multiview: mas_multiview {
    style.fill: "#fff"
  }
  mas_tracker: mas_tracker {
    style.fill: "#fff"
  }
  mas_policy: mas_policy\n(WIP) {
    style: {
      fill: "#fff"
      stroke: "#4a90d9"
      stroke-dash: 5
    }
  }
  mas_common_frame: mas_common_frame {
    style.fill: "#fff"
  }
  mas_offboard: mas_offboard {
    style.fill: "#fff"
  }
  mavros: MAVROS {
    style.fill: "#fff"
  }
  point_to_region: "gimbal_controller\n(point_to_region)" {
    style.fill: "#fff"
  }

  # mas_mission — state machine: IDLE → TRACKING → MISSION
  # Replaces the anonymous gate; owns mode transitions and command routing.
  # - TRACKING: forwards point_to_region gimbal/zoom, blocks policy commands
  # - MISSION:  forwards policy cmd_vel/gimbal/zoom, blocks point_to_region
  mas_mission: "mas_mission\n(WIP)" {
    style: {
      fill: "#fff"
      stroke: "#4a90d9"
      stroke-dash: 5
    }
  }

  # ── Internal edges ──

  ultralytics_ros -> mas_multiview: "detections\n(bbox, tracker_id)"
  ultralytics_ros -> mas_policy: "detections\n(ego bbox)"
  mas_multiview -> mas_tracker: "triangulated points\n(pos, cov, detection_ids)\ntarget_rays_w"
  mas_tracker -> mas_policy: "chosen_target_pose\n(pos, cov)\nchosen_target_ray_w"
  mas_common_frame -> mas_policy: "<mission frame>\npose, cov(pos, ori)\nvel(lin/ang)"
  mavros -> mas_common_frame: "<local frame>\npose, cov(pos, ori)\nvel(lin/ang)"
  mavros -> mas_policy: "lin acc"

  # Policy → mas_mission → downstream
  mas_policy -> mas_mission: "cmd vel(lin/yaw)\ncmd gimbal los rate\ncmd zoom rate"
  point_to_region -> mas_mission: "cmd gimbal LOS angle\ncmd zoom"
  mas_mission -> mas_offboard: "(MISSION)\ncmd vel"

  mas_offboard -> mavros: "cmd vel"

  # ── Sim/Real boundaries (launch-config) ──
  # These are NOT runtime nodes. They represent the sim/real boundary
  # where launch-config determines which source is active.
  # Drawn as dashed rectangles to distinguish from active ROS2 nodes.

  camera_boundary: "camera\n(launch-config)" {
    shape: rectangle
    style: {
      fill: "#f0f0f0"
      stroke: "#888"
      stroke-dash: 5
      font-size: 12
    }
  }
  fc_boundary: "flight ctrl\n(launch-config)" {
    shape: rectangle
    style: {
      fill: "#f0f0f0"
      stroke: "#888"
      stroke-dash: 5
      font-size: 12
    }
  }
  gimbal_boundary: "gimbal\n(launch-config)" {
    shape: rectangle
    style: {
      fill: "#f0f0f0"
      stroke: "#888"
      stroke-dash: 5
      font-size: 12
    }
  }

  # Boundary → internal consumers
  camera_boundary -> ultralytics_ros: "camera feed"
  camera_boundary -> mas_multiview: "base intrinsics\nzoom level"
  fc_boundary -> mavros: "MAVLink"
  gimbal_boundary -> mas_multiview: "gimbal joint angles\nzoom level"
  gimbal_boundary -> point_to_region: "gimbal joint angles"
  mas_mission -> gimbal_boundary: "cmd gimbal\ncmd zoom"
  mas_common_frame -> gimbal_boundary: "aircraft attitude"
}

# ═══════════════════════════════════════════════════════════
# Sim Env (orange)
# ═══════════════════════════════════════════════════════════

sim: "Sim Env" {
  style: {
    fill: "#ffe0d0"
    stroke: "#d97a4a"
    stroke-width: 2
  }

  isaac_sim: Isaac Sim {
    style.fill: "#fff"
  }

  pegasus_simulator: PegasusSimulator {
    style.fill: "#fff"
  }
  px4_sitl: PX4 SITL {
    style.fill: "#fff"
  }
  gimbal_stabilizer: gimbal_stabilizer {
    style.fill: "#fff"
  }

  target: Target {
    style: {
      fill: "#fff"
      stroke: "#d97a4a"
    }

    mavros_tgt: MAVROS {
      style.fill: "#fff"
    }
    mas_common_frame_tgt: mas_common_frame {
      style.fill: "#fff"
    }

    mavros_tgt -> mas_common_frame_tgt
  }

  isaac_sim -> pegasus_simulator: states
  pegasus_simulator -> isaac_sim: commands
  pegasus_simulator <-> px4_sitl: states\ncommands
}

# ═══════════════════════════════════════════════════════════
# Real-world (pink)
# ═══════════════════════════════════════════════════════════

real: "Real-world" {
  style: {
    fill: "#f8d7e8"
    stroke: "#d94a8a"
    stroke-width: 2
  }

  usb_cam: usb_cam {
    style.fill: "#fff"
  }
  siyi_gimbal_node: siyi_gimbal_node {
    style.fill: "#fff"
  }
  px4_real: PX4 (real) {
    style.fill: "#fff"
  }
}

# ═══════════════════════════════════════════════════════════
# Operator (triggers state transitions via service call)
# ═══════════════════════════════════════════════════════════

operator: "Operator" {
  shape: oval
  style: {
    fill: "#fff3cd"
    stroke: "#d9a74a"
    stroke-width: 2
  }
}

# ═══════════════════════════════════════════════════════════
# Cross-boundary edges
# ═══════════════════════════════════════════════════════════

# ── Agent N+1 → Agent N (cross-agent) ──

# Cross-agent: peer common_frame → ego policy (position, velocity, ang_vel, zoom)
agent_n1.mas_common_frame_n1 -> agent_n.mas_policy: "<mission frame>\npos, vel(lin)\ncombined_ang_vel_w\nzoom_level" {
  style.stroke: "#2d6a2d"
}
# Cross-agent: peer multiview → ego multiview (pre-computed bearing rays for triangulation)
agent_n1.mas_multiview_n1 -> agent_n.mas_multiview: "target_rays_w\n(bearing rays)" {
  style.stroke: "#2d6a2d"
}
# Cross-agent: peer tracker → ego policy (selected target ray)
agent_n1.mas_tracker_n1 -> agent_n.mas_policy: "chosen_target_ray_w" {
  style.stroke: "#2d6a2d"
}
# Cross-agent: peer detection status → ego policy (compact Bool)
agent_n1.ultralytics_ros_n1 -> agent_n.mas_policy: "bbox_empty\n(Bool)" {
  style.stroke: "#2d6a2d"
}

# ── Sim Env → Boundaries ──

sim.pegasus_simulator -> agent_n.camera_boundary: "camera feed\nbase intrinsics\nzoom level" {
  style.stroke: "#d97a4a"
}
sim.px4_sitl <-> agent_n.fc_boundary: "MAVLink" {
  style.stroke: "#d97a4a"
}
sim.gimbal_stabilizer <- agent_n.gimbal_boundary: "cmd gimbal\ncmd zoom\naircraft attitude" {
  style.stroke: "#d97a4a"
}
sim.pegasus_simulator -> agent_n.gimbal_boundary: "gimbal joint angles\nzoom level" {
  style.stroke: "#d97a4a"
}
sim.target.mas_common_frame_tgt -> agent_n.point_to_region: "target position"

# ── Real-world → Boundaries ──

real.usb_cam -> agent_n.camera_boundary: "camera feed\nbase intrinsics" {
  style.stroke: "#d94a8a"
}
real.px4_real <-> agent_n.fc_boundary: "MAVLink" {
  style.stroke: "#d94a8a"
}
real.siyi_gimbal_node <- agent_n.gimbal_boundary: "cmd gimbal\ncmd zoom\naircraft attitude" {
  style.stroke: "#d94a8a"
}
real.siyi_gimbal_node -> agent_n.gimbal_boundary: "gimbal joint angles\nzoom level" {
  style.stroke: "#d94a8a"
}

# ── Operator → mas_mission ──

operator -> agent_n.mas_mission: "mission select" {
  style: {
    stroke: "#d9a74a"
    stroke-width: 2
  }
}
operator -> agent_n.mas_tracker: "target select" {
  style: {
    stroke: "#d9a74a"
    stroke-width: 2
  }
}
# ── mas_mission publishes mission_state for offboard to consume ──

agent_n.mas_mission -> agent_n.mas_offboard: "mission_state"
