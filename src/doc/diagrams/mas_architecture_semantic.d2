# MAS (Multi-Agent C-UAS System, Per-Vehicle Decentralized Architecture)
# Semantic-level Architecture Diagram
# Render: d2 mas_architecture_semantic.d2 mas_architecture_semantic.svg --layout=elk

direction: right

title: {
  label: "MAS (Multi-Agent C-UAS System, Per-Vehicle Decentralized Architecture)"
  near: top-center
  shape: text
  style: {
    font-size: 24
    bold: true
  }
}

# ═══════════════════════════════════════════════════════════
# Agent N+1 (peer instance, green)
# ═══════════════════════════════════════════════════════════

agent_n1: "Agent N+1 (MAS instance)" {
  style: {
    fill: "#d4edda"
    stroke: "#6abf69"
    stroke-width: 2
    multiple: true
  }

  mavros_n1: MAVROS {
    style.fill: "#fff"
  }
  mas_common_frame_n1: mas_common_frame {
    style.fill: "#fff"
  }
  ultralytics_ros_n1: ultralytics_ros {
    style.fill: "#fff"
  }

  mavros_n1 -> mas_common_frame_n1
  ultralytics_ros_n1 -> mas_common_frame_n1
}

# ═══════════════════════════════════════════════════════════
# Agent N (main instance, blue)
# ═══════════════════════════════════════════════════════════

agent_n: "Agent N (MAS instance N)" {
  style: {
    fill: "#dbeeff"
    stroke: "#4a90d9"
    stroke-width: 2
  }

  ultralytics_ros: ultralytics_ros {
    style.fill: "#fff"
  }
  mas_multiview: mas_multiview {
    style.fill: "#fff"
  }
  mas_tracker: mas_tracker {
    style.fill: "#fff"
  }
  mas_policy: mas_policy\n(WIP) {
    style: {
      fill: "#fff"
      stroke: "#4a90d9"
      stroke-dash: 5
    }
  }
  mas_common_frame: mas_common_frame {
    style.fill: "#fff"
  }
  mas_offboard: mas_offboard {
    style.fill: "#fff"
  }
  mavros: MAVROS {
    style.fill: "#fff"
  }
  point_to_region: "gimbal_controller\n(point_to_region)" {
    style.fill: "#fff"
  }

  # mas_mission — state machine: IDLE → TRACKING → MISSION
  # Replaces the anonymous gate; owns mode transitions and command routing.
  # - TRACKING: forwards point_to_region gimbal/zoom, blocks policy commands
  # - MISSION:  forwards policy cmd_vel/gimbal/zoom, blocks point_to_region
  mas_mission: "mas_mission\n(WIP)" {
    style: {
      fill: "#fff"
      stroke: "#4a90d9"
      stroke-dash: 5
    }
  }

  # ── Internal edges ──

  ultralytics_ros -> mas_multiview: "bbox_xywh\ntimestamp"
  ultralytics_ros -> mas_policy: "bbox_xywh\ntimestamp"
  mas_multiview -> mas_tracker: "target pos est (all)\ntarget pos cov (all)"
  mas_tracker -> mas_policy: "target pos est (selected)\ntarget pos cov (selected)"
  mas_common_frame -> mas_policy: "<mission frame>\npose, cov(pos, ori)\nvel(lin/ang)"
  mavros -> mas_common_frame: "<local frame>\npose, cov(pos, ori)\nvel(lin/ang)"
  mavros -> mas_policy: "lin acc"

  # Policy → mas_mission → downstream
  mas_policy -> mas_mission: "cmd vel(lin/yaw)\ncmd gimbal los rate\ncmd zoom rate"
  point_to_region -> mas_mission: "cmd gimbal LOS angle\ncmd zoom"
  mas_mission -> mas_offboard: "(MISSION)\ncmd vel"

  mas_offboard -> mavros: "cmd vel"

  # ── Sim/Real switches (WIP) ──
  # Each switch receives both sim and real interface counterparts.
  # Only one source is active at a time (determined by deployment config).

  camera_switch: "camera\nswitch" {
    shape: diamond
    style: {
      fill: "#e8e8e8"
      stroke: "#888"
      font-size: 12
    }
  }
  fc_switch: "flight ctrl\nswitch" {
    shape: diamond
    style: {
      fill: "#e8e8e8"
      stroke: "#888"
      font-size: 12
    }
  }
  gimbal_switch: "gimbal\nswitch" {
    shape: diamond
    style: {
      fill: "#e8e8e8"
      stroke: "#888"
      font-size: 12
    }
  }

  # Switch → internal consumers
  camera_switch -> ultralytics_ros: "camera feed"
  camera_switch -> mas_multiview: "base intrinsics\nzoom level"
  fc_switch -> mavros: "MAVLink"
  gimbal_switch -> mas_multiview: "gimbal joint angles/LOS\nzoom level"
  gimbal_switch -> point_to_region: "gimbal state"
  mas_mission -> gimbal_switch: "cmd gimbal\ncmd zoom"
  mas_common_frame -> gimbal_switch: "aircraft attitude"
}

# ═══════════════════════════════════════════════════════════
# Sim Env (orange)
# ═══════════════════════════════════════════════════════════

sim: "Sim Env" {
  style: {
    fill: "#ffe0d0"
    stroke: "#d97a4a"
    stroke-width: 2
  }

  isaac_sim: Isaac Sim {
    style.fill: "#fff"
  }

  pegasus_simulator: PegasusSimulator {
    style.fill: "#fff"
  }
  px4_sitl: PX4 SITL {
    style.fill: "#fff"
  }
  gimbal_stabilizer: gimbal_stabilizer {
    style.fill: "#fff"
  }

  target: Target {
    style: {
      fill: "#fff"
      stroke: "#d97a4a"
    }

    mavros_tgt: MAVROS {
      style.fill: "#fff"
    }
    mas_common_frame_tgt: mas_common_frame {
      style.fill: "#fff"
    }

    mavros_tgt -> mas_common_frame_tgt
  }

  isaac_sim -> pegasus_simulator: states
  pegasus_simulator -> isaac_sim: commands
  pegasus_simulator <-> px4_sitl: states\ncommands
}

# ═══════════════════════════════════════════════════════════
# Real-world (pink)
# ═══════════════════════════════════════════════════════════

real: "Real-world" {
  style: {
    fill: "#f8d7e8"
    stroke: "#d94a8a"
    stroke-width: 2
  }

  usb_cam: usb_cam {
    style.fill: "#fff"
  }
  siyi_gimbal_node: siyi_gimbal_node {
    style.fill: "#fff"
  }
  px4_real: PX4 (real) {
    style.fill: "#fff"
  }
}

# ═══════════════════════════════════════════════════════════
# Operator (triggers state transitions via service call)
# ═══════════════════════════════════════════════════════════

operator: "Operator" {
  shape: oval
  style: {
    fill: "#fff3cd"
    stroke: "#d9a74a"
    stroke-width: 2
  }
}

# ═══════════════════════════════════════════════════════════
# Cross-boundary edges
# ═══════════════════════════════════════════════════════════

# ── Agent N+1 → Agent N (cross-agent) ──

agent_n1.mas_common_frame_n1 -> agent_n.mas_policy: "<mission frame>\npos, vel(lin)\nray_w, combined ang vel\nzoom level" {
  style.stroke: "#2d6a2d"
}
agent_n1.mas_common_frame_n1 -> agent_n.mas_multiview: "<mission frame>\nray_w\npose, cov(pos, ori)" {
  style.stroke: "#2d6a2d"
}
agent_n1.ultralytics_ros_n1 -> agent_n.mas_policy: "bbox empty" {
  style.stroke: "#2d6a2d"
}

# ── Sim Env → Switches ──

sim.pegasus_simulator -> agent_n.camera_switch: "camera feed\nbase intrinsics\nzoom level" {
  style.stroke: "#d97a4a"
}
sim.px4_sitl <-> agent_n.fc_switch: "MAVLink" {
  style.stroke: "#d97a4a"
}
sim.gimbal_stabilizer <- agent_n.gimbal_switch: "cmd gimbal\ncmd zoom\naircraft attitude" {
  style.stroke: "#d97a4a"
}
sim.pegasus_simulator -> agent_n.gimbal_switch: "gimbal joint angles/LOS\nzoom level" {
  style.stroke: "#d97a4a"
}
sim.target.mas_common_frame_tgt -> agent_n.point_to_region: "target position"

# ── Real-world → Switches ──

real.usb_cam -> agent_n.camera_switch: "camera feed\nbase intrinsics" {
  style.stroke: "#d94a8a"
}
real.px4_real <-> agent_n.fc_switch: "MAVLink" {
  style.stroke: "#d94a8a"
}
real.siyi_gimbal_node <- agent_n.gimbal_switch: "cmd gimbal\ncmd zoom\naircraft attitude" {
  style.stroke: "#d94a8a"
}
real.siyi_gimbal_node -> agent_n.gimbal_switch: "gimbal joint angles/LOS\nzoom level" {
  style.stroke: "#d94a8a"
}

# ── Operator → mas_mission ──

operator -> agent_n.mas_mission: "mission select" {
  style: {
    stroke: "#d9a74a"
    stroke-width: 2
  }
}
operator -> agent_n.mas_tracker: "target select" {
  style: {
    stroke: "#d9a74a"
    stroke-width: 2
  }
}
# ── mas_mission publishes mission_state for offboard to consume ──

agent_n.mas_mission -> agent_n.mas_offboard: "mission_state"
