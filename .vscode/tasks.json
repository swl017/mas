{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "source ROS2", // Renamed for clarity
            "type": "shell",
            // Source scripts, print env vars (filtering internal ones), save to .ros_env file
            "command": "bash -c 'source /opt/ros/galactic/setup.bash && source ${workspaceFolder}/install/setup.bash && env | grep -v ^_= > ${workspaceFolder}/.vscode/.ros_env'",
            "problemMatcher": []
            // Removed options.shell as default behavior is usually sufficient
        }
    ]
}
