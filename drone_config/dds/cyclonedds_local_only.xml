<?xml version="1.0" encoding="UTF-8" ?>
<!--
  CycloneDDS profile used by zenoh-bridge-ros2dds (the bridge embeds
  CycloneDDS internally; our local ROS2 nodes still use FastDDS via
  drone_config/dds/fastdds_local_only.xml).

  Restricts the bridge's CycloneDDS to localhost + the gimbal-side
  Ethernet — never WiFi. Same goal as the FastDDS profile: prevent
  cross-vehicle DDS chatter from causing the IMU throttle described in
  ticket 038.

  Each Jetson has only one of the 192.168.144.* addresses bound on its
  interface (.101 on veh1, .102 on veh2). CycloneDDS only uses entries
  it can actually find; the unused address is silently ignored.

  Activated via CYCLONEDDS_URI in src/tmux/drone.tmuxp.yaml's
  zenoh-bridge window.
-->
<CycloneDDS xmlns="https://cdds.io/config"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="https://cdds.io/config
              https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">
  <Domain id="any">
    <General>
      <Interfaces>
        <NetworkInterface address="192.168.144.101" multicast="default" />
        <NetworkInterface address="192.168.144.102" multicast="default" />
      </Interfaces>
      <AllowMulticast>spdp</AllowMulticast>
    </General>
  </Domain>
</CycloneDDS>
