<?xml version="1.0" encoding="UTF-8" ?>
<!--
  FastDDS profile that binds all local DDS traffic to localhost + the
  baseboard internal Ethernet (gimbal-side, 192.168.144.0/24). WiFi is
  excluded so cross-vehicle DDS chatter cannot trigger the Jetson IMU
  throttle described in
    src/doc/active/tickets/038-mavros-dual-vehicle-imu-degradation/ticket.md

  Cross-vehicle topic flow is handled by zenoh-bridge-dds — see ticket 039.

  Single XML serves both vehicles: each Jetson only has ONE of the
  192.168.144.* addresses bound on its gimbal-side interface (.101 on veh1,
  .102 on veh2), and FastDDS uses whichever it finds locally. The unused
  address in the whitelist is simply ignored.

  To activate, set in the shell that launches ROS2 nodes:
    export FASTRTPS_DEFAULT_PROFILES_FILE=/home/usrg/mas/drone_config/dds/fastdds_local_only.xml
  (already exported via drone_config/robot.env).
-->
<dds xmlns="http://www.eprosima.com">
  <profiles>
    <transport_descriptors>
      <transport_descriptor>
        <transport_id>local_only_udp</transport_id>
        <type>UDPv4</type>
        <interfaceWhiteList>
          <address>127.0.0.1</address>
          <address>192.168.144.101</address>
          <address>192.168.144.102</address>
        </interfaceWhiteList>
      </transport_descriptor>

      <transport_descriptor>
        <transport_id>local_shm</transport_id>
        <type>SHM</type>
      </transport_descriptor>
    </transport_descriptors>

    <participant profile_name="local_only_participant" is_default_profile="true">
      <rtps>
        <userTransports>
          <transport_id>local_only_udp</transport_id>
          <transport_id>local_shm</transport_id>
        </userTransports>
        <useBuiltinTransports>false</useBuiltinTransports>
      </rtps>
    </participant>
  </profiles>
</dds>
