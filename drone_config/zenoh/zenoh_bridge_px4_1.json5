// zenoh-bridge-dds v0.5.x config for vehicle1 (px4_1, ROS_DOMAIN_ID=1).
// Background: src/doc/active/tickets/039-zenoh-direct-cross-vehicle-bridge/ticket.md
//
// Switched from the prebuilt zenoh-bridge-ros2dds v1.9.0 binary back to the
// apt-installed `ros-humble-zenoh-bridge-dds` (v0.5.x) because the prebuilt
// bundled a newer CycloneDDS that wouldn't interop with the apt
// rmw_cyclonedds_cpp 0.10.x running on local ROS2 nodes — bridge started
// cleanly but never discovered any local DDS publishers.
//
// Pairs with drone_config/zenoh/zenoh_bridge_px4_2.json5 on the other Jetson.
// Together they form a 2-peer Zenoh mesh over WiFi TCP/7447.
//
// Run via:
//   ros2 run zenoh_bridge_dds zenoh_bridge_dds -c \
//     /home/usrg/mas/drone_config/zenoh/zenoh_bridge_px4_1.json5

{
  mode: "peer",

  // Listen on this Jetson's WiFi IP. Peer connects here.
  listen: {
    endpoints: ["tcp/192.168.0.14:7447"]
  },

  // Connect outbound to vehicle2's Jetson WiFi IP.
  connect: {
    endpoints: ["tcp/192.168.0.8:7447"]
  },

  // Disable multicast scouting — the peer is static and reachable via the
  // explicit `connect`/`listen` endpoints above. Multicast on WiFi is
  // exactly what we're avoiding.
  scouting: {
    multicast: { enabled: false },
    gossip: { enabled: true }
  },

  plugins: {
    // zenoh-bridge-dds v0.5.x uses `plugins.dds` (the newer
    // zenoh-bridge-ros2dds uses `plugins.ros2dds` — different schema).
    dds: {
      // Local DDS domain that this bridge bridges from/to.
      domain: 1,

      // Allowlist regex — single string covering the 5 cross-vehicle peer
      // topics from mas_policy/CONTEXT.md plus mavros/state and
      // mavros/imu/data (added during development for smoke testing).
      // The bridge subscribes locally to topics matching this regex AND
      // re-publishes any incoming Zenoh-bridged topics that match.
      allow: "^/(px4_1|px4_2)/(mavros/state|mavros/imu/data|common_frame/odom|combined_ang_vel_w|yolo_result_active|camera/zoom_level|policy/observation)$"
    }
  }
}
